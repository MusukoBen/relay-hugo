# deactivate mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine off
</IfModule>

# Apache <= 2.2
<IfModule !mod_authz_core.c>
  # No Password
  Satisfy Any

  # All allowed to access
  Order allow,deny
  Allow from all
</IfModule>

# Apache >= 2.3
<IfModule mod_authz_core.c>
  # No Password
  Satisfy Any

  # All allowed to access
  Require all granted
</IfModule>